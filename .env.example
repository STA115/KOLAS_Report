# OpenAI settings for analysis backend.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Backend server settings.
PORT=8080
# Comma-separated list of allowed browser origins.
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,https://sta115.github.io"

# MySQL settings used by server.js.
DB_HOST="127.0.0.1"
DB_PORT=3306
DB_USER=""
DB_PASSWORD=""
DB_NAME=""
# Set DB_SSL=true if your managed DB requires SSL.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_CONNECTION_LIMIT=10

# Optional browser-exposed key (not recommended for production).
VITE_OPENAI_API_KEY=""

# Optional frontend proxy target.
# Leave empty for same-origin local proxy (/gemini-analyze), or set deployed backend URL.
VITE_API_BASE_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
