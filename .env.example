# OpenAI settings for analysis backend.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Optional browser-exposed key (not recommended for production).
VITE_OPENAI_API_KEY=""

# MySQL settings (used by /login and all DB routes in server.js)
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_USER=""
DB_PASSWORD=""
DB_NAME=""
DB_CONNECTION_LIMIT="10"

# Optional frontend proxy target.
# Leave empty for same-origin local proxy (/gemini-analyze), or set deployed backend URL.
VITE_API_BASE_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
