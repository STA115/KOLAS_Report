# OpenAI settings for analysis backend.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# MySQL settings for backend login and analysis APIs.
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_USER=""
DB_PASSWORD=""
DB_NAME=""
PORT="8080"

# Auth settings (required in production).
JWT_SECRET="change-this-secret"
AUTH_COOKIE_NAME="kolas_auth_token"
AUTH_TOKEN_EXPIRES_IN="1h"
AUTH_COOKIE_MAX_AGE_MS="3600000"
AUTH_BCRYPT_ROUNDS="12"
LOGIN_RATE_LIMIT_MAX="10"

# CORS allow-list (comma separated).
# Add deployed frontend origins as needed (example includes GitHub Pages).
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,https://sta115.github.io"
# If you access dev frontend via LAN IP, add it too:
# e.g. http://192.168.0.10:3000
ALLOW_NULL_ORIGIN="false"

# Optional browser-exposed key (not recommended for production).
VITE_OPENAI_API_KEY=""

# Optional frontend proxy target.
# Leave empty for same-origin local proxy (/gemini-analyze), or set deployed backend URL.
# For GitHub Pages, this must be your backend origin (example: https://kolas-api.onrender.com).
VITE_API_BASE_URL=""
VITE_PROXY_TARGET="http://localhost:8080"

# Frontend base path used at build time. Use "/" for intranet root hosting.
VITE_BASE_PATH="/KOLAS_Report/"

# Backend static serving options (for same-origin intranet deployment).
SERVE_FRONTEND="false"
FRONTEND_BASE_PATH="/KOLAS_Report"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
