# OpenAI settings for analysis backend.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Optional browser-exposed key (not recommended for production).
VITE_OPENAI_API_KEY=""

# Optional frontend proxy target.
# Leave empty for same-origin local proxy (/gemini-analyze), or set deployed backend URL.
VITE_API_BASE_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
