# OpenAI settings for analysis backend.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# MySQL settings for backend login and analysis APIs.
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_USER=""
DB_PASSWORD=""
DB_NAME=""

# Auth settings (required in production).
JWT_SECRET="change-this-secret"
AUTH_COOKIE_NAME="kolas_auth_token"
AUTH_TOKEN_EXPIRES_IN="1h"
AUTH_COOKIE_MAX_AGE_MS="3600000"
AUTH_BCRYPT_ROUNDS="12"
LOGIN_RATE_LIMIT_MAX="10"

# CORS allow-list (comma separated). Empty means allow all origins.
CORS_ORIGINS=""

# Optional browser-exposed key (not recommended for production).
VITE_OPENAI_API_KEY=""

# Optional frontend proxy target.
# Leave empty for same-origin local proxy (/gemini-analyze), or set deployed backend URL.
VITE_API_BASE_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
