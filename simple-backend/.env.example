PORT="8080"
NODE_ENV="development"

# Use a long random string in production.
JWT_SECRET="change-this-secret"
AUTH_COOKIE_NAME="kolas_auth_token"
AUTH_TOKEN_EXPIRES_IN="1h"
AUTH_COOKIE_MAX_AGE_MS="3600000"

# Comma-separated list. Leave empty to allow all origins.
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# SQLite file path (relative to project root by default).
SQLITE_FILE="simple-backend/data/auth.db"

# Optional: create a default admin user on startup.
DEFAULT_ADMIN_ID=""
DEFAULT_ADMIN_PASSWORD=""
DEFAULT_ADMIN_EMAIL=""
